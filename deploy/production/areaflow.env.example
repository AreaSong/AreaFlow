AREAFLOW_ENV=production
AREAFLOW_HOST=0.0.0.0
AREAFLOW_PUBLIC_BASE_URL=https://areaflow.example.com
AREAFLOW_TRUSTED_PROXY_CIDRS=10.0.0.0/8

AREAFLOW_DATABASE_URL=postgres://areaflow@postgres.example/areaflow?sslmode=verify-full
AREAFLOW_DB_MAX_CONNECTIONS=30
AREAFLOW_DB_MIN_CONNECTIONS=5
AREAFLOW_DB_CONNECT_TIMEOUT=5s
AREAFLOW_DB_ACQUIRE_TIMEOUT=5s
AREAFLOW_DB_QUERY_TIMEOUT=10s
AREAFLOW_DB_MAX_CONNECTION_IDLE=5m
AREAFLOW_DB_MAX_CONNECTION_LIFETIME=30m

AREAFLOW_AUTH_MODE=oidc
AREAFLOW_OIDC_ISSUER_URL=https://id.example.com
AREAFLOW_OIDC_CLIENT_ID=areaflow
AREAFLOW_OIDC_CLIENT_SECRET_FILE=/run/secrets/oidc-client-secret
AREAFLOW_OIDC_REDIRECT_URL=https://areaflow.example.com/api/v1/auth/oidc/callback
AREAFLOW_OIDC_GROUPS_CLAIM=groups
AREAFLOW_OIDC_BOOTSTRAP_SUBJECTS=replace-with-approved-subject
AREAFLOW_SESSION_SECRET_FILE=/run/secrets/session-secret
AREAFLOW_SESSION_IDLE_TTL=8h
AREAFLOW_SESSION_ABSOLUTE_TTL=24h
AREAFLOW_TOKEN_MAX_TTL=2160h

AREAFLOW_ARTIFACT_BACKEND=s3
AREAFLOW_S3_REGION=us-east-1
AREAFLOW_S3_BUCKET=areaflow-production
AREAFLOW_S3_ENDPOINT=
AREAFLOW_S3_USE_PATH_STYLE=false

AREAFLOW_METRICS_HOST=0.0.0.0
OTEL_SERVICE_NAME=areaflow
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com
