{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AreaFlow",
  "version": "1.0.0",
  "identifier": "com.areasong.areaflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5175",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AreaFlow",
        "width": 980,
        "height": 720,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:3847 http://localhost:3847; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
